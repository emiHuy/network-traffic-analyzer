# ── NETAnalyzer environment configuration ──────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit secrets.
#
# ── Port / deployment strategy ─────────────────────────────────────────────────
#
#  DEV  mode  (two processes, two ports)
#  ┌───────────────────────────────────────────────────────────┐
#  │  Terminal 1: cd backend && uvicorn main:app --reload      │  → port 8000
#  │  Terminal 2: cd frontend && npm run dev                   │  → port 5173
#  │                                                           │
#  │  Vite proxies /sessions, /capture, /network, /ai to       │
#  │  localhost:8000 automatically. Open http://localhost:5173.│
#  └───────────────────────────────────────────────────────────┘
#
#  PROD mode  (single process, single port)
#  ┌────────────────────────────────────────────────────────────────┐
#  │  1. cd frontend && npm run build   (emits to backend/static/)  │
#  │  2. cd backend  && uvicorn main:app --host 0.0.0.0 --port 8000 │
#  │                                                                │
#  │  FastAPI serves both the React SPA and the API on :8000.       │
#  │  Open http://localhost:8000  (or your machine's IP).           │
#  └────────────────────────────────────────────────────────────────┘

# ── Database ────────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# Defaults to ../../netanalyzer.db relative to core/config.py if not set.
DB_PATH=../netanalyzer.db

# ── Capture ─────────────────────────────────────────────────────────────────────
# Network interface for packet capture.
# Windows: "Wi-Fi" or "Ethernet"
# Linux:   "eth0", "wlan0", etc.
# macOS:   "en0", "en1", etc.
CAPTURE_INTERFACE=Wi-Fi

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the FastAPI CORS middleware.
# Only needed in DEV mode when Vite runs on a different port.
# In PROD mode the frontend is served by FastAPI itself, so CORS is irrelevant.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI Analysis ──────────────────────────────────────────────────────────────────
# Google Gemini API key — free tier available at https://aistudio.google.com/apikey
# If set here, the frontend AI panel will use it automatically (no UI prompt).
# If left blank, users can supply their own key through the AI Analysis panel.
GEMINI_API_KEY=your_gemini_api_key_here
