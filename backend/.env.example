# ── Database ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file
# Defaults to ../../netanalyzer.db relative to core/config.py if not set
DB_PATH=../netanalyzer.db

# ── Capture ────────────────────────────────────────────────────────────────────
# Network interface to capture packets on
# Windows: "Wi-Fi" or "Ethernet"
# Linux:   "eth0", "wlan0", etc.
# Mac:     "en0", "en1", etc.
CAPTURE_INTERFACE=Wi-Fi

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI Analysis ────────────────────────────────────────────────────────────────
# Google Gemini API key — free tier available at https://aistudio.google.com/apikey
# Used by the /ai/* routes to power the AI analysis panel in the frontend.
GEMINI_API_KEY=your_gemini_api_key_here
